# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# Virtual environments
venv/
.venv/
env/
.conda/

# ============================================
# Jupyter Notebooks
# ============================================
.ipynb_checkpoints/

# ============================================
# ML Model Artifacts
# ============================================
# Checkpoints, weights, saved models
*.pt
*.pth
*.onnx
*.h5
*.hdf5
*.keras
*.pkl
*.joblib
*.safetensors
checkpoints/
models/**

# Allow final product models
!models/final/*.pt
!models/final/*.onnx
!models/final/*.mlpackage
!models/final/*.xml
!models/final/*.bin

# TensorBoard logs
*.tfevents*

# ============================================
# Geospatial Data (large files)
# ============================================
# Raster imagery
*.tif
*.tiff
*.geotiff
*.img
*.jp2
*.ecw
*.sid
*.vrt

# Vector formats
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx
*.kml
*.kmz

# Geodatabases
*.gdb/
*.gpkg

# Note: GeoJSON can be large or small.
# Uncomment the line below if your GeoJSONs are large.
# *.geojson

# ============================================
# Other Data & Output
# ============================================
data/**
output/
results/
predictions/
tiles/
annotations/
qgis/
*.csv
*.parquet
*.npy
*.npz
*.zip
*.tar.gz
*.7z

# Allow cd boundaries
!data/boundaries/*.shp
!data/boundaries/*.shx
!data/boundaries/*.dbf
!data/boundaries/*.prj
!data/boundaries/*.cpg
!data/boundaries/*.sr.lock

# ============================================
# Config & Secrets
# ============================================
.env
.env.*
*.secret
credentials/

# ============================================
